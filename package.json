{
  "name": "cast-interface",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform presentation prototype with reusable content hierarchy, slide rendering, and NDI RGBA output",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/rebuild-better-sqlite3.mjs electron",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-vitest-with-native-rebuild.mjs run",
    "test:watch": "node scripts/run-vitest-with-native-rebuild.mjs --watch",
    "test:e2e": "playwright test",
    "capture:ui-screenshots": "npm run build && node app/e2e/capture-ui-screenshots.mjs",
    "rebuild:better-sqlite3:node": "node scripts/rebuild-better-sqlite3.mjs node",
    "rebuild:better-sqlite3:electron": "node scripts/rebuild-better-sqlite3.mjs electron",
    "build:ndi-native": "npm --prefix packages/ndi-native run build",
    "clean:ndi-native": "npm --prefix packages/ndi-native run clean",
    "rebuild:ndi-native": "npm --prefix packages/ndi-native run rebuild"
  },
  "dependencies": {
    "@cast-interface/ndi-native": "file:packages/ndi-native",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "better-sqlite3": "^11.7.0",
    "jsdom": "^28.1.0",
    "konva": "^10.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.1",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.2",
    "vite": "^5.4.14"
  }
}
