{
  "name": "recast",
  "productName": "Recast",
  "version": "0.1.3",
  "private": true,
  "description": "Cross-platform presentation tool with reusable content hierarchy, slide rendering, and NDI output",
  "author": "IT-PSAPE",
  "packageManager": "npm@11.6.2",
  "homepage": "https://github.com/IT-PSAPE/cast-interface#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/IT-PSAPE/cast-interface.git"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch",
    "pretest:e2e": "npm run build && npm run e2e:install",
    "test:e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "capture:ui-screenshots": "npm run build && node app/e2e/capture-ui-screenshots.mjs",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "build:ndi-native": "npm --prefix packages/ndi-native run build",
    "clean:ndi-native": "npm --prefix packages/ndi-native run clean",
    "rebuild:ndi-native": "npm --prefix packages/ndi-native run rebuild"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@recast/ndi-native": "file:packages/ndi-native",
    "@tailwindcss/vite": "^4.2.1",
    "konva": "^10.2.0",
    "lucide-react": "^1.7.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "jsdom": "^28.1.0",
    "to-ico": "^1.1.5",
    "typescript": "^5.8.2",
    "vite": "^5.4.14",
    "vitest": "^4.0.18"
  }
}
