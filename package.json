{
  "name": "lumora",
  "productName": "Lumora",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform presentation prototype with reusable content hierarchy, slide rendering, and offscreen-rendered NDI output",
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "out/main/index.js",
  "scripts": {
    "setup:windows-native": "powershell.exe -ExecutionPolicy Bypass -File scripts/setup-windows-native-dev.ps1",
    "setup:windows-native:tools": "powershell.exe -ExecutionPolicy Bypass -File scripts/setup-windows-native-dev.ps1 -ToolsOnly",
    "check:windows-native": "powershell.exe -ExecutionPolicy Bypass -File scripts/setup-windows-native-dev.ps1 -CheckOnly",
    "check:windows-native:build": "powershell.exe -ExecutionPolicy Bypass -File scripts/setup-windows-native-dev.ps1 -CheckOnly -BuildNativeAddon",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "capture:ui-screenshots": "npm run build && node app/e2e/capture-ui-screenshots.mjs",
    "build:ndi-native": "npm --prefix packages/ndi-native run build",
    "clean:ndi-native": "npm --prefix packages/ndi-native run clean",
    "rebuild:ndi-native": "npm --prefix packages/ndi-native run rebuild"
  },
  "dependencies": {
    "@lumora/ndi-native": "file:packages/ndi-native",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^28.1.0",
    "konva": "^10.2.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.1",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.2",
    "vite": "^5.4.14"
  }
}
