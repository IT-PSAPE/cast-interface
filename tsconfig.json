{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["app/core/*"],
      "@database/*": ["app/database/*"],
      "@renderer/*": ["app/renderer/*"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "app/**/*.ts",
    "app/**/*.tsx"
  ]
}
